# ===========================================
# STURNA.AI — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================================

# Server
PORT=8000
ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/sturna

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI (agent inference)
OPENAI_API_KEY=sk-your-openai-key-here

# Blockchain (zk-SNARK verifier)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-project-id
VERIFIER_CONTRACT_ADDRESS=0x_your_contract_address

# VIGIL (runtime monitoring)
VIGIL_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
VIGIL_LOG_LEVEL=info

# Audit Logger (compliance sink)
AUDIT_STORAGE_URL=s3://your-bucket/audit-logs
AUDIT_STORAGE_ACCESS_KEY=your_access_key
AUDIT_STORAGE_SECRET_KEY=your_secret_key

# SEC 17a-4 Retention
RETENTION_DAYS=2555

# Optional: Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Optional: Stripe (billing)
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret